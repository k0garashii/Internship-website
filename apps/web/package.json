{
    "name": "web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "lint": "next lint",
        "test": "npm run clean:next && npm run build && tsx --test tests/**/*.test.ts",
        "worker": "tsx scripts/run-worker.ts",
        "jobs:drain": "tsx scripts/run-worker.ts --once",
        "personas:seed": "tsx scripts/seed-personas.ts",
        "personas:notion": "tsx scripts/sync-personas-notion.ts",
        "personas:evaluate": "tsx scripts/evaluate-persona-searches.ts",
        "ci:check": "npm run db:validate && npm run lint && npm run test",
        "clean:next": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\"",
        "postinstall": "prisma generate",
        "db:format": "prisma format",
        "db:validate": "prisma validate",
        "db:generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "next": "15.5.13",
        "pdf-parse": "^2.4.5",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "15.5.13",
        "playwright-core": "^1.58.2",
        "prisma": "^6.19.2",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "typescript": "^5"
    },
    "engines": {
        "node": "22.x"
    }
}

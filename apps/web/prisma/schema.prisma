generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING_DELETION
}

enum WorkspaceType {
  PERSONAL
  TEAM
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  BILLING
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum BillingProvider {
  INTERNAL
  STRIPE
  LEMONSQUEEZY
}

enum BillingInterval {
  MONTHLY
  YEARLY
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum WorkspaceFeature {
  SEARCH_DISCOVERY
  EMAIL_DRAFT_GENERATION
  EMAIL_GMAIL_SYNC
  EMAIL_GMAIL_SEND
  COMPANY_TARGETING
  PROFILE_ENRICHMENT
  API_ACCESS
}

enum EntitlementSource {
  PLAN
  OVERRIDE
}

enum AppJobType {
  PROFILE_ENRICHMENT_REFRESH
  SEARCH_DISCOVERY_RUN
  GMAIL_SYNC
}

enum AppJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ExperienceLevel {
  INTERN
  ENTRY_LEVEL
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum EmploymentType {
  INTERNSHIP
  APPRENTICESHIP
  FULL_TIME
  PART_TIME
  TEMPORARY
  FREELANCE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum DomainSource {
  MANUAL
  GEMINI
  IMPORTED
}

enum TargetSource {
  MANUAL
  GEMINI
  IMPORTED
}

enum SearchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
  CANCELED
}

enum OfferSourceKind {
  COMPANY_CAREERS
  JOB_BOARD
  AGENCY
  REFERRAL
  OTHER
}

enum OfferLifecycleStatus {
  DISCOVERED
  NORMALIZED
  SCORED
  SHORTLISTED
  APPLIED
  ARCHIVED
}

enum FeedbackDecision {
  NOT_RELEVANT
  MAYBE
  FAVORITE
  APPLIED
  INTERVIEWING
  REJECTED
  OFFER_ACCEPTED
}

enum DraftStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  SENT
  ARCHIVED
}

enum EmailIngestionSourceType {
  FORWARDING
  GMAIL
  OUTLOOK
}

enum EmailIngestionConnectionStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum MailboxMessageDirection {
  INBOUND
  OUTBOUND
}

enum MailboxReplyStatus {
  NONE
  OUTBOUND_ONLY
  RESPONSE_RECEIVED
  INTERVIEW
  REJECTION
  OFFER
}

enum InboundEmailStatus {
  RECEIVED
  PARSED
  IGNORED
  FAILED
}

enum EmailDeliveryLogStatus {
  SUCCESS
  FAILED
}

enum EmailDeliveryOperation {
  GMAIL_DRAFT
  GMAIL_SEND
  ADHOC_GMAIL_SEND
}

enum InboundEmailSignal {
  UNKNOWN
  JOB_ALERT
  CAREER_SITE_DIGEST
  RECRUITER_OUTREACH
  SCHOOL_CAREER_DIGEST
  APPLICATION_UPDATE
}

enum ProfileEnrichmentStatus {
  PENDING
  READY
  FAILED
}

enum SearchPreferenceAxis {
  ROLE
  DOMAIN
  KEYWORD
  TECHNOLOGY
  LOCATION
  WORK_MODE
  EMPLOYMENT_TYPE
  COMPANY
  COMPANY_TYPE
  OUTCOME
}

enum SearchPreferencePolarity {
  POSITIVE
  NEGATIVE
}

enum SearchPreferenceConfidence {
  LOW
  MEDIUM
  HIGH
}

enum SearchSignalStrength {
  WEAK
  MEDIUM
  STRONG
  OUTCOME
}

enum SearchBehaviorEventType {
  SEARCH_PLAN_VIEWED
  SEARCH_EXECUTED
  SEARCH_RESULT_OPENED
  SEARCH_RESULT_EXPANDED
  COMPANY_TARGET_OPENED
  ATS_SOURCE_OPENED
  OFFER_SAVED
  OFFER_DELETED
  OFFER_FEEDBACK_FAVORITE
  OFFER_FEEDBACK_MAYBE
  OFFER_FEEDBACK_NOT_RELEVANT
  DRAFT_GENERATED
  EMAIL_SENT
  EMAIL_REPLY_RECEIVED
  INTERVIEW_RECORDED
  REJECTION_RECORDED
  OFFER_ACCEPTED_RECORDED
}

model User {
  id                       String                      @id @default(cuid())
  email                    String                      @unique
  passwordHash             String?
  fullName                 String?
  locale                   String                      @default("fr-FR")
  timezone                 String                      @default("Europe/Paris")
  status                   UserStatus                  @default(ACTIVE)
  activeWorkspaceId        String?
  emailVerifiedAt          DateTime?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  activeWorkspace          Workspace?                  @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  accounts                 AuthAccount[]
  billingEvents            BillingEvent[]              @relation("BillingActor")
  companyWatchlist         CompanyWatchlistItem[]
  drafts                   EmailDraft[]
  emailConnections         EmailIngestionConnection[]
  workspaceInvitationsSent WorkspaceInvitation[]       @relation("WorkspaceInvitationActor")
  feedbackEntries          OfferFeedback[]
  emailDeliveryLogs        EmailDeliveryLog[]
  inboundEmails            InboundEmail[]
  jobOffers                JobOffer[]
  profile                  UserProfile?
  profileEnrichment        UserProfileEnrichment?
  mailboxSignals           OfferMailboxSignal[]
  searchDomains            SearchDomain[]
  searchLocations          SearchLocation[]
  searchRuns               SearchRun[]
  searchTargets            SearchTarget[]
  sessions                 AuthSession[]
  mailboxMessages          MailboxMessage[]
  workspaceMembers         WorkspaceMember[]
  workspacesCreated        Workspace[]                 @relation("WorkspaceCreator")
  jobs                     AppJob[]
  searchBehaviorEvents     SearchBehaviorEvent[]
  searchProfileInference   UserSearchProfileInference?

  @@index([activeWorkspaceId])
  @@index([status])
}

model Workspace {
  id                      String                       @id @default(cuid())
  slug                    String                       @unique
  name                    String
  type                    WorkspaceType                @default(PERSONAL)
  createdByUserId         String?
  personalOwnerUserId     String?                      @unique
  defaultLocale           String                       @default("fr-FR")
  defaultTimezone         String                       @default("Europe/Paris")
  isArchived              Boolean                      @default(false)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  createdBy               User?                        @relation("WorkspaceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  activeForUsers          User[]                       @relation("UserActiveWorkspace")
  members                 WorkspaceMember[]
  invitations             WorkspaceInvitation[]
  subscriptions           WorkspaceSubscription[]
  entitlements            WorkspaceEntitlement[]
  billingEvents           BillingEvent[]
  jobs                    AppJob[]
  userProfiles            UserProfile[]
  companyWatchlist        CompanyWatchlistItem[]
  searchDomains           SearchDomain[]
  searchTargets           SearchTarget[]
  searchLocations         SearchLocation[]
  searchRuns              SearchRun[]
  jobOffers               JobOffer[]
  feedbackEntries         OfferFeedback[]
  drafts                  EmailDraft[]
  emailDeliveryLogs       EmailDeliveryLog[]
  emailConnections        EmailIngestionConnection[]
  inboundEmails           InboundEmail[]
  mailboxMessages         MailboxMessage[]
  mailboxSignals          OfferMailboxSignal[]
  profileEnrichments      UserProfileEnrichment[]
  searchBehaviorEvents    SearchBehaviorEvent[]
  searchProfileInferences UserSearchProfileInference[]

  @@index([createdByUserId])
  @@index([isArchived])
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(MEMBER)
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, role])
}

model WorkspaceInvitation {
  id              String                    @id @default(cuid())
  workspaceId     String
  invitedByUserId String?
  email           String
  normalizedEmail String
  role            WorkspaceMemberRole       @default(MEMBER)
  token           String                    @unique
  status          WorkspaceInvitationStatus @default(PENDING)
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedByUser   User?                     @relation("WorkspaceInvitationActor", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, normalizedEmail, status])
  @@index([workspaceId, status])
}

model Plan {
  id                String                  @id @default(cuid())
  code              String                  @unique
  name              String
  provider          BillingProvider         @default(INTERNAL)
  billingInterval   BillingInterval         @default(MONTHLY)
  priceCents        Int                     @default(0)
  currency          String                  @default("EUR")
  isDefault         Boolean                 @default(false)
  featureMatrix     Json
  externalProductId String?
  externalPriceId   String?
  isArchived        Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  subscriptions     WorkspaceSubscription[]

  @@index([provider, isDefault])
}

model WorkspaceSubscription {
  id                     String             @id @default(cuid())
  workspaceId            String
  planId                 String
  provider               BillingProvider    @default(INTERNAL)
  status                 SubscriptionStatus @default(ACTIVE)
  externalSubscriptionId String?
  seats                  Int                @default(1)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  metadata               Json?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingEvents          BillingEvent[]

  @@index([workspaceId, status])
  @@index([planId])
}

model WorkspaceEntitlement {
  id          String            @id @default(cuid())
  workspaceId String
  feature     WorkspaceFeature
  source      EntitlementSource @default(OVERRIDE)
  enabled     Boolean           @default(true)
  limitValue  Int?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, feature])
  @@index([workspaceId, enabled])
}

model BillingEvent {
  id              String                 @id @default(cuid())
  workspaceId     String
  actorUserId     String?
  subscriptionId  String?
  provider        BillingProvider        @default(INTERNAL)
  eventType       String
  externalEventId String?
  payload         Json?
  createdAt       DateTime               @default(now())
  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUser       User?                  @relation("BillingActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  subscription    WorkspaceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([subscriptionId])
}

model AuthAccount {
  id                String                     @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accountType       String                     @default("oauth")
  refreshToken      String?
  accessToken       String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  emailConnections  EmailIngestionConnection[]
  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expiresAt  DateTime

  @@unique([identifier, token])
}

model UserProfile {
  id                   String           @id @default(cuid())
  userId               String           @unique
  workspaceId          String?
  headline             String?
  summary              String?
  school               String?
  degree               String?
  graduationYear       Int?
  city                 String?
  countryCode          String?
  remotePreference     WorkMode?
  experienceLevel      ExperienceLevel?
  availabilityDate     DateTime?
  linkedinUrl          String?
  githubUrl            String?
  portfolioUrl         String?
  resumeUrl            String?
  visaNeedsSponsorship Boolean          @default(false)
  salaryExpectationMin Int?
  salaryExpectationMax Int?
  constraints          Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  skills               ProfileSkill[]
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model ProfileSkill {
  id              String      @id @default(cuid())
  profileId       String
  name            String
  normalizedName  String
  level           SkillLevel?
  yearsExperience Int?
  isHighlighted   Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  profile         UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, normalizedName])
  @@index([profileId])
}

model CompanyWatchlistItem {
  id             String     @id @default(cuid())
  userId         String
  workspaceId    String?
  companyName    String
  normalizedName String
  websiteUrl     String?
  careerPageUrl  String?
  notes          String?
  priority       Int        @default(50)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, normalizedName])
  @@index([userId, priority])
  @@index([workspaceId])
}

model SearchDomain {
  id              String       @id @default(cuid())
  userId          String
  workspaceId     String?
  label           String
  normalizedLabel String
  source          DomainSource @default(MANUAL)
  rationale       String?
  isValidated     Boolean      @default(false)
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, normalizedLabel])
  @@index([userId, isValidated])
  @@index([workspaceId])
}

model SearchTarget {
  id              String           @id @default(cuid())
  userId          String
  workspaceId     String?
  title           String
  normalizedTitle String
  source          TargetSource     @default(MANUAL)
  experienceLevel ExperienceLevel?
  contractTypes   EmploymentType[]
  notes           String?
  priority        Int              @default(50)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, normalizedTitle])
  @@index([userId, priority])
  @@index([workspaceId])
}

model SearchLocation {
  id              String     @id @default(cuid())
  userId          String
  workspaceId     String?
  label           String
  normalizedLabel String
  countryCode     String?
  region          String?
  isRemote        Boolean    @default(false)
  isHybrid        Boolean    @default(false)
  priority        Int        @default(50)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, normalizedLabel])
  @@index([userId, priority])
  @@index([workspaceId])
}

model SearchRun {
  id              String                @id @default(cuid())
  userId          String
  workspaceId     String?
  label           String
  queryText       String?
  status          SearchRunStatus       @default(PENDING)
  filtersSnapshot Json?
  startedAt       DateTime?
  completedAt     DateTime?
  resultCount     Int                   @default(0)
  errorMessage    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  searchMatches   SearchRunOffer[]
  behaviorEvents  SearchBehaviorEvent[]
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([workspaceId])
}

model JobOffer {
  id              String                @id @default(cuid())
  userId          String
  workspaceId     String?
  sourceKind      OfferSourceKind
  sourceSite      String
  sourceUrl       String
  externalId      String?
  fingerprint     String
  companyName     String
  companyWebsite  String?
  title           String
  locationLabel   String?
  countryCode     String?
  employmentType  EmploymentType?
  workMode        WorkMode?
  experienceLevel ExperienceLevel?
  salaryMin       Int?
  salaryMax       Int?
  currency        String?
  description     String?
  rawPayload      Json?
  status          OfferLifecycleStatus  @default(DISCOVERED)
  postedAt        DateTime?
  firstSeenAt     DateTime              @default(now())
  lastSeenAt      DateTime              @default(now())
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  drafts          EmailDraft[]
  feedbackEntries OfferFeedback[]
  mailboxSignals  OfferMailboxSignal[]
  searchMatches   SearchRunOffer[]
  behaviorEvents  SearchBehaviorEvent[]
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mailboxMessages MailboxMessage[]
  workspace       Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, fingerprint])
  @@index([userId, status])
  @@index([userId, postedAt])
  @@index([workspaceId])
}

model SearchRunOffer {
  id               String    @id @default(cuid())
  searchRunId      String
  jobOfferId       String
  discoveredAt     DateTime  @default(now())
  rank             Int?
  rawScore         Float?
  normalizedScore  Float?
  matchExplanation String?
  isShortlisted    Boolean   @default(false)
  jobOffer         JobOffer  @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  searchRun        SearchRun @relation(fields: [searchRunId], references: [id], onDelete: Cascade)

  @@unique([searchRunId, jobOfferId])
  @@index([jobOfferId])
}

model OfferFeedback {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String?
  jobOfferId  String
  decision    FeedbackDecision
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  jobOffer    JobOffer         @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([jobOfferId, decision])
  @@index([workspaceId])
}

model EmailDraft {
  id                     String                @id @default(cuid())
  userId                 String
  workspaceId            String?
  jobOfferId             String?
  status                 DraftStatus           @default(DRAFT)
  recipientEmail         String?
  subject                String?
  body                   String
  personalizationSummary String?
  generatedBy            String?
  deliveryProvider       String?
  gmailDraftId           String?
  gmailMessageId         String?
  gmailThreadId          String?
  contextSnapshot        Json?
  approvedAt             DateTime?
  sentAt                 DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  deliveryLogs           EmailDeliveryLog[]
  behaviorEvents         SearchBehaviorEvent[]
  jobOffer               JobOffer?             @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)
  user                   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace              Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([jobOfferId])
  @@index([workspaceId])
}

model EmailDeliveryLog {
  id                String                 @id @default(cuid())
  userId            String
  workspaceId       String?
  emailDraftId      String?
  provider          String
  operation         EmailDeliveryOperation
  status            EmailDeliveryLogStatus
  recipientEmail    String
  subject           String?
  bodyPreview       String?
  errorMessage      String?
  providerDraftId   String?
  providerMessageId String?
  providerThreadId  String?
  metadata          Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  emailDraft        EmailDraft?            @relation(fields: [emailDraftId], references: [id], onDelete: SetNull)
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([emailDraftId])
  @@index([workspaceId])
}

model EmailIngestionConnection {
  id                  String                         @id @default(cuid())
  userId              String
  workspaceId         String?
  authAccountId       String?
  sourceType          EmailIngestionSourceType
  label               String
  status              EmailIngestionConnectionStatus @default(ACTIVE)
  mailboxAddress      String?
  syncCursor          String?
  syncQuery           String?
  syncLabel           String?
  lastSyncedAt        DateTime?
  lastSyncError       String?
  forwardingLocalPart String?
  forwardingAddress   String?
  webhookSecretHash   String?
  lastIngestedAt      DateTime?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  authAccount         AuthAccount?                   @relation(fields: [authAccountId], references: [id], onDelete: SetNull)
  inboundEmails       InboundEmail[]
  mailboxMessages     MailboxMessage[]
  user                User                           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace?                     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceType])
  @@unique([forwardingLocalPart])
  @@index([authAccountId])
  @@index([userId, status])
  @@index([workspaceId])
}

model InboundEmail {
  id                String                   @id @default(cuid())
  userId            String
  workspaceId       String?
  connectionId      String
  externalMessageId String?
  fromEmail         String?
  fromName          String?
  toEmail           String?
  subject           String?
  bodyPreview       String?
  snippet           String?
  canonicalUrl      String?
  signal            InboundEmailSignal       @default(UNKNOWN)
  processingStatus  InboundEmailStatus       @default(RECEIVED)
  receivedAt        DateTime
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  connection        EmailIngestionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([connectionId, externalMessageId])
  @@index([userId, receivedAt])
  @@index([connectionId, processingStatus])
  @@index([workspaceId])
}

model MailboxMessage {
  id                String                   @id @default(cuid())
  userId            String
  workspaceId       String?
  connectionId      String
  jobOfferId        String?
  providerMessageId String
  providerThreadId  String?
  direction         MailboxMessageDirection
  folderLabel       String?
  subject           String?
  normalizedSubject String?
  snippet           String?
  fromEmail         String?
  fromName          String?
  toEmails          Json?
  ccEmails          Json?
  canonicalUrl      String?
  signal            InboundEmailSignal       @default(UNKNOWN)
  processingStatus  InboundEmailStatus       @default(RECEIVED)
  sentAt            DateTime?
  receivedAt        DateTime?
  rawPayload        Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  connection        EmailIngestionConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  jobOffer          JobOffer?                @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)
  replySignals      OfferMailboxSignal[]
  behaviorEvents    SearchBehaviorEvent[]
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([connectionId, providerMessageId])
  @@index([userId, providerThreadId])
  @@index([jobOfferId, receivedAt])
  @@index([connectionId, sentAt])
  @@index([connectionId, receivedAt])
  @@index([connectionId, processingStatus])
  @@index([workspaceId])
}

model OfferMailboxSignal {
  id               String             @id @default(cuid())
  userId           String
  workspaceId      String?
  jobOfferId       String
  mailboxMessageId String?
  providerThreadId String?
  status           MailboxReplyStatus @default(NONE)
  confidence       Float              @default(0)
  summary          String?
  details          Json?
  detectedAt       DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  jobOffer         JobOffer           @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)
  mailboxMessage   MailboxMessage?    @relation(fields: [mailboxMessageId], references: [id], onDelete: SetNull)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, jobOfferId])
  @@index([jobOfferId, status])
  @@index([userId, detectedAt])
  @@index([workspaceId])
}

model UserProfileEnrichment {
  id             String                  @id @default(cuid())
  userId         String                  @unique
  workspaceId    String?
  status         ProfileEnrichmentStatus @default(PENDING)
  sourceSnapshot Json?
  extractedData  Json?
  summary        String?
  lastError      String?
  lastEnrichedAt DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([status, lastEnrichedAt])
  @@index([workspaceId])
}

model SearchBehaviorEvent {
  id               String                  @id @default(cuid())
  userId           String
  workspaceId      String?
  type             SearchBehaviorEventType
  axisSummary      SearchPreferenceAxis[]
  strength         SearchSignalStrength
  dedupeKey        String?                 @unique
  queryText        String?
  companyName      String?
  companySlug      String?
  sourceUrl        String?
  jobOfferId       String?
  searchRunId      String?
  emailDraftId     String?
  mailboxMessageId String?
  signalPayload    Json?
  metadata         Json?
  occurredAt       DateTime
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  jobOffer         JobOffer?               @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)
  searchRun        SearchRun?              @relation(fields: [searchRunId], references: [id], onDelete: SetNull)
  emailDraft       EmailDraft?             @relation(fields: [emailDraftId], references: [id], onDelete: SetNull)
  mailboxMessage   MailboxMessage?         @relation(fields: [mailboxMessageId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([type, occurredAt])
  @@index([jobOfferId])
  @@index([searchRunId])
  @@index([emailDraftId])
  @@index([mailboxMessageId])
}

model UserSearchProfileInference {
  id               String     @id @default(cuid())
  userId           String     @unique
  workspaceId      String?
  version          Int        @default(1)
  declaredSnapshot Json?
  inferredSnapshot Json?
  diagnostics      Json?
  eventCount       Int        @default(0)
  lastEventAt      DateTime?
  lastComputedAt   DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, lastComputedAt])
}

model AppJob {
  id           String       @id @default(cuid())
  workspaceId  String?
  userId       String?
  type         AppJobType
  status       AppJobStatus @default(PENDING)
  payload      Json
  scheduledAt  DateTime?
  availableAt  DateTime     @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  attemptCount Int          @default(0)
  maxAttempts  Int          @default(5)
  lastError    String?
  lockToken    String?
  lockedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  runs         AppJobRun[]
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([type, status])
  @@index([workspaceId])
  @@index([userId])
}

model AppJobRun {
  id           String       @id @default(cuid())
  jobId        String
  status       AppJobStatus
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  errorMessage String?
  output       Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  job          AppJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}
